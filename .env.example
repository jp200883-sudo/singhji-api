# 🦁 Singh Ji AI Ultra — Environment Variables
# Copy to .env and fill values

# Render
PORT=5000
FLASK_ENV=production

# APIs (FREE TIER)
NEWSAPI_KEY=your_newsapi_key_here
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password

# UPI/Banking
UPI_ID=jp200883@sbi
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Social Media (Free APIs)
INSTAGRAM_TOKEN=your_token
FACEBOOK_TOKEN=your_token
TWITTER_BEARER=your_token

# Emergency
EMERGENCY_CONTACT_1=+91XXXXXXXXXX
EMERGENCY_CONTACT_2=+91XXXXXXXXXX
POLICE_NUMBER=100
AMBULANCE_NUMBER=108

# F5-TTS Voice
F5_TTS_MODEL_PATH=./models/f5-tts
JP_SINGH_SAMPLE=./voice_samples/jp_singh.wav
