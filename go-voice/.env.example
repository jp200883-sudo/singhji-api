# Singh Ji AI Voice Server - Environment Variables
# Copy to .env and fill in your API keys

# Server
PORT=8080
ENV=development

# STT Providers
WHISPER_MODEL_PATH=./models/whisper-base
VOSK_MODEL_PATH=./models/vosk-en
GOOGLE_STT_KEY=your_google_stt_key_here

# Translation
INDICTRANS2_URL=
SEAMLESSM4T_URL=
GOOGLE_TRANSLATE_KEY=your_google_translate_key_here

# AI Brain
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
LOCAL_LLM_URL=http://localhost:11434

# TTS
MINIMAX_API_KEY=your_minimax_key_here
EDGE_TTS_PATH=edge-tts
PIPER_MODEL_PATH=./models/piper-en
KOKORO_MODEL_PATH=./models/kokoro

# Voice Clone
COQUI_XTTS_PATH=./models/coqui-xtts-v2
FISH_AUDIO_KEY=your_fish_audio_key_here
ORPHEUS_MODEL_PATH=./models/orpheus

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here
SUPABASE_BUCKET=voice-files

# Audio Settings (Singh Ji Standard)
SAMPLE_RATE=16000
BIT_DEPTH=16
CHANNELS=1
BITRATE=32
MAX_FILE_SIZE=10485760
MAX_DURATION=30s

# Queue
QUEUE_WORKERS=10
QUEUE_SIZE=1000

# WebSocket
WS_READ_BUFFER=1024
WS_WRITE_BUFFER=1024
WS_MAX_MESSAGE=10485760
